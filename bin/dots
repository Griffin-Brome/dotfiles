#! /bin/bash
#
# Converts configuration file names from ".{name}" to "dot-{name}", for use 
# with GNU Stow's "--dotfiles" flag

# Iterate over all directories in working directory, find dotfiles
for filename in */-[a-zA-Z]*; do
  # https://www.guyrutenberg.com/2009/01/12/batch-renaming-using-sed/
  mv "$filename" "$(echo "$filename" | sed 's/-dot/dot-/')"
done 
